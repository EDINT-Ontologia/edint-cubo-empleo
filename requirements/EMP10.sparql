# EMP10: ¿Cuál es el número de contratos registrados por tipo de contrato en una región administrativa y periodo concretos?

PREFIX edintemp: <http://vocab.linkeddata.es/datosabiertos/def/actividad-economica/cubo-empleo#>
PREFIX qb: <http://purl.org/linked-data/cube#>
PREFIX edintdimension: <http://vocab.linkeddata.es/datosabiertos/def/dimension#>
PREFIX edintmeasure: <http://vocab.linkeddata.es/datosabiertos/def/measure#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?contractType ?contractTypeLabel (SUM(?value) AS ?registeredContracts)
WHERE {
  ?obs a qb:Observation ;
       qb:dataSet edinttemp: ;
       edintdimension:refAdminRegion ?region ;
       edintdimension:refPeriod ?period ;
       edintdimension:contractType ?contractType ;
       edintmeasure:registeredContractsCount ?value .

  FILTER(?region = <URI_REGION>)
  FILTER(?period = <URI_PERIODO>)

  OPTIONAL { ?contractType skos:prefLabel ?contractTypeLabel . FILTER(LANG(?contractTypeLabel) = "es") }
}
GROUP BY ?contractType ?contractTypeLabel
ORDER BY DESC(?registeredContracts)