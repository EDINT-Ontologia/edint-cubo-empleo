    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#age">
        <rdfs:comment xml:lang="en">Attribute that indicates the age of an individual, usually expressed in years or grouped into age ranges for classification purposes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Característica de una persona que indica cuántos años tiene en un momento determinado, ya sea mediante un valor concreto o mediante un grupo de edad.</rdfs:comment>
        <rdfs:label xml:lang="en">Age</rdfs:label>
        <rdfs:label xml:lang="es">Edad</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#contractType">
        <rdfs:comment xml:lang="es">Tipo de contrato laboral asociado a la observación de empleo, cuando aplique.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of employment contract associated with the employment observation, when applicable.</rdfs:comment>
        <rdfs:label xml:lang="en">Contract Type</rdfs:label>
        <rdfs:label xml:lang="es">Tipo de contrato</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#economicActivity">
        <rdfs:comment xml:lang="es">Actividad económica asociada a la observación de empleo, representada mediante una clasificación controlada como la CNAE.</rdfs:comment>
        <rdfs:comment xml:lang="en">Economic activity associated with the employment observation, represented using a controlled classification such as CNAE.</rdfs:comment>
        <rdfs:label xml:lang="es">Actividad económica</rdfs:label>
        <rdfs:label xml:lang="en">Economic activity</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion">
        <rdfs:comment xml:lang="en">Administrative region associated.</rdfs:comment>
        <rdfs:comment xml:lang="es">Región administrativa asociada.</rdfs:comment>
        <rdfs:label xml:lang="en">Reference Administrative Region</rdfs:label>
        <rdfs:label xml:lang="es">Región Administrativa de Referencia</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod">
        <rdfs:comment xml:lang="en">Period of time or point in time to which the measured observation is intended to refer.</rdfs:comment>
        <rdfs:comment xml:lang="es">Período de tiempo o punto en el tiempo al que se destina la observación medida.</rdfs:comment>
        <rdfs:label xml:lang="es">Periodo de Referencia</rdfs:label>
        <rdfs:label xml:lang="en">Reference Period</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#sector">
        <rdfs:comment xml:lang="es">Sector temático asociado a la observación de empleo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Thematic sector associated with the employment observation.</rdfs:comment>
        <rdfs:label xml:lang="en">Sector</rdfs:label>
        <rdfs:label xml:lang="es">Sector</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#sex">
        <rdfs:comment xml:lang="en">Attribute used to represent the sex category associated with an individual in a given data collection context.</rdfs:comment>
        <rdfs:comment xml:lang="es">Característica de una persona que permite clasificarla dentro de una categoría sexual utilizada en un determinado contexto estadístico, administrativo o de registro.</rdfs:comment>
        <rdfs:label xml:lang="en">Sex</rdfs:label>
        <rdfs:label xml:lang="es">Sexo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#activePopulationCount">
        <rdfs:comment xml:lang="en">Number of active persons in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de personas activas en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Active population count</rdfs:label>
        <rdfs:label xml:lang="es">Número de activos</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#employedPopulationCount">
        <rdfs:comment xml:lang="en">Number of employed persons in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de personas ocupadas en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Employed population count</rdfs:label>
        <rdfs:label xml:lang="es">Número de ocupados</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#jobProfiles">
        <rdfs:comment xml:lang="en">Job profiles generated in specific economic sectors, according to the NACE classification.</rdfs:comment>
        <rdfs:comment xml:lang="es">Perfiles de empleo generados en sectores económicos específicos, según la clasificación CNAE.</rdfs:comment>
        <rdfs:label xml:lang="en">Job profiles</rdfs:label>
        <rdfs:label xml:lang="es">Perfiles de empleo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#jobSeekersCount">
        <rdfs:comment xml:lang="en">Number of registered job seekers in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de demandantes de empleo registrados en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Job seekers count</rdfs:label>
        <rdfs:label xml:lang="es">Número de demandantes de empleo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#registeredContractsCount">
        <rdfs:comment xml:lang="en">Number of employment contracts registered in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de contratos de trabajo registrados en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="es">Número de contratos registrados</rdfs:label>
        <rdfs:label xml:lang="en">Registered contracts count</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#registeredUnemploymentCount">
        <rdfs:comment xml:lang="en">Number of persons in registered unemployment according to SEPE administrative records, for the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de personas en situación de paro registrado según los registros administrativos del SEPE, en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="es">Número de paro registrado</rdfs:label>
        <rdfs:label xml:lang="en">Registered unemployment count</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#socialSecurityAffiliatesCount">
        <rdfs:comment xml:lang="en">Number of persons affiliated with the Social Security system in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de personas afiliadas al sistema de Seguridad Social en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="es">Número de personas afiliadas a la Seguridad Social</rdfs:label>
        <rdfs:label xml:lang="en">Social Security affiliates count</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#unemployedPopulationCount">
        <rdfs:comment xml:lang="en">Number of unemployed persons in the reference period and administrative division.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de personas desempleadas en el periodo de referencia y la división administrativa correspondiente.</rdfs:comment>
        <rdfs:label xml:lang="es">Número de parados</rdfs:label>
        <rdfs:label xml:lang="en">Unemployed population count</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://lod.ine.es/def/vocabulary/employmentRate">
        <rdfs:comment xml:lang="es">La tasa representa la proporción entre las personas empleadas y la población en edad de trabajar, ajustada tanto por calendario como estacionalmente.</rdfs:comment>
        <rdfs:label xml:lang="en">Employment rate</rdfs:label>
        <rdfs:label xml:lang="es">Tasa de empleo de la población</rdfs:label>
        <vocabulary:inMeasureSet rdf:resource="https://lod.ine.es/def/vocabulary/rate"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://lod.ine.es/def/vocabulary/jobs">
        <rdfs:comment xml:lang="en">Jobs generated in specific economic sectors, according to the NACE classification.</rdfs:comment>
        <rdfs:comment xml:lang="es">Puestos de trabajo generados en sectores económicos específicos, según la clasificación CNAE.</rdfs:comment>
        <rdfs:label xml:lang="en">Jobs</rdfs:label>
        <rdfs:label xml:lang="es">Puestos de trabajo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://lod.ine.es/def/vocabulary/numberOfPeople">
        <rdfs:comment xml:lang="es">Cada uno de los elementos que forman parte de la población de personas.</rdfs:comment>
        <rdfs:label xml:lang="en">Number of people</rdfs:label>
        <rdfs:label xml:lang="es">Población</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://lod.ine.es/def/vocabulary/unemploymentRate">
        <rdfs:comment xml:lang="es">La tasa de desempleo es la proporción de la población activa que no tiene trabajo. Las personas desempleadas son aquellas en edad de trabajar que no tienen empleo, están disponibles para trabajar y, en las últimas cuatro semanas, han realizado acciones específicas para encontrar trabajo.</rdfs:comment>
        <rdfs:label xml:lang="es">Tasa de paro</rdfs:label>
        <rdfs:label xml:lang="en">Unemployment rate</rdfs:label>
        <vocabulary:inMeasureSet rdf:resource="https://lod.ine.es/def/vocabulary/rate"/>
    </rdf:Description>
</rdf:RDF>



